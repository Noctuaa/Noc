---
import '../styles/main.css';
import Navigation from './Navigation.vue';
import Footer from './Footer.astro';
---

<!doctype html>
<html lang="en">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;900&display=swap" rel="stylesheet" />

  <title>Noc</title>

  <style is:inline>
    [data-animate] {
      opacity: 0;
      visibility: hidden;
    }
  </style>
  <noscript>
    <style>
      [data-animate] {
        opacity: 1;
        visibility: visible;
      }
    </style>
  </noscript>

  <body>
    <Navigation client:load />
    <div class="teleport-container"></div>
    <slot />
    <Footer />
    <script>
      import { initLenis, initCurtainEffect, initAnchorLinks } from '../utils/ScrollManager.ts';
      import { initAnimations } from '../utils/AnimationManager';

      window.addEventListener('DOMContentLoaded', () => {
        initLenis();        // 1. Smooth scroll first
        initCurtainEffect(); // 2. Curtain (depends on scroll)
        initAnchorLinks();   // 3. Anchor links
        initAnimations();    // 4. Animations last (ScrollTrigger calculates after)
      });
    </script>
  </body>


</html>
