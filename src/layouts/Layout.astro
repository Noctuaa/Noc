---
import '../styles/main.css';
import Navigation from './Navigation.vue';
import Footer from './Footer.astro';
---

<!doctype html>
<html lang="fr">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- <link rel="icon" type="image/svg+xml" href="/favicon.svg" /> -->
  <meta name="generator" content={Astro.generator} />
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin="/" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;900&display=swap"
    rel="stylesheet"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;900&display=swap"
      rel="stylesheet"
    />
  </noscript>

  <title>Nocdev | Développeur d'application</title>
  <meta
    name="description"
    content="Bienvenue sur Nocdev, développeur d'application freelance spécialisé en interfaces modernes et performantes."
  />

  <!-- Open Graph -->
  <meta property="og:title" content="Nocdev | Développeur d'application" />
  <meta
    property="og:description"
    content="Bienvenue sur Nocdev, développeur d'application freelance spécialisé en interfaces modernes et performantes."
  />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://nocdev.fr" />

  <!-- Sitemap -->
  <link rel="sitemap" href="/sitemap-index.xml" />

  <style is:inline>
    [data-animate] {
      opacity: 0;
      visibility: hidden;
    }
  </style>
  <noscript>
    <style>
      [data-animate] {
        opacity: 1;
        visibility: visible;
      }
    </style>
  </noscript>

  <body>
    <Navigation client:load />
    <div class="teleport-container"></div>
    <slot />
    <Footer />
    <script>
      import { initLenis, initAnchorLinks } from '../utils/ScrollManager.ts';
      import { initAnimations } from '../utils/AnimationManager';

      window.addEventListener('DOMContentLoaded', () => {
        initLenis(); // 1. Smooth scroll first
        initAnchorLinks(); // 3. Anchor links
        initAnimations(); // 4. Animations last (ScrollTrigger calculates after)
      });
    </script>
  </body>


</html>
