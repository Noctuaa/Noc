---
import { encodedMailto, encodedEmail } from '../utils/EncodeEmail.ts';
import Modal from '../components/Modal.vue';

const currentYear = new Date().getFullYear();
const email = import.meta.env.PUBLIC_EMAIL_TO;
---

<footer class="footer p-relative">
  <svg class="wave-footer" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 
  1440 100" preserveAspectRatio="none">
    <path d="M0,0 L0,40 Q360,100 720,40 T1440,40 L1440,0 Z"></path>
  </svg>

  <div class="container">
    <div class="footer-brand d-grid gap-2 mb-6">
      <h2 class="brand-name">Nocdev</h2>
    </div>
    <div class="separator-h separator-h-gradient"></div>
    <div class="footer-bottom d-flex jc-between pt-4">
      <div class="footer-legal d-flex gap-2">
        <Modal title="Mentions légales" client:visible>
          <h4>Éditeur du site</h4>
          <p>
            <strong>Noctua</strong>
            <br />
            Développeur d'Application
            <br />
            France
            <br />
            Email : <a href={`mailto:${encodedMailto(email)}`} set:html={encodedEmail(email)} />
          </p>
          <h4>Hébergement</h4>
          <p>
            <strong>PlanetHoster</strong>
            <br />
            4416 Louis B. Mayer
            <br />
            Laval, QC H7P 0G1, Canada
          </p>
          <h4>Propriété intellectuelle</h4>
          <p>Tous droits réservés. Ce portfolio est protégé par le droit d'auteur.</p>
        </Modal>
        <span class="footer-sep" aria-hidden="true">·</span>
        <Modal title="Politique de confidentialité" client:visible>
          <h4>Données collectées</h4>
          <p>Via le formulaire de contact :</p>
          <ul>
            <li>Nom et prénom</li>
            <li>Adresse email</li>
            <li>Message</li>
          </ul>
          <h4>Utilisation</h4>
          <p>Ces données servent uniquement à répondre à vos demandes.</p>
          <h4>Vos droits</h4>
          <p>
            Accès, rectification, suppression :
            <a href={`mailto:${encodedMailto(email)}`} set:html={encodedEmail(email)} />
          </p>
        </Modal>
      </div>
      <div class="copy">
        <p class="m-0">© {currentYear} Nocdev</p>
      </div>
    </div>
  </div>
</footer>
