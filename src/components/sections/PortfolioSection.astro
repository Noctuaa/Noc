---
import ProjectAccordion from '../portfolio/ProjectAccordion.vue';
---

<section id="portfolio" class="section bg-alt">
  <div class="container">
    <div class="section-header">
      <h2>Portfolio</h2>
      <div class="separator-h separator-h-gradient"></div>
      <p class="section-description">Découvrez mes projets et réalisations techniques.</p>
    </div>
    <ProjectAccordion client:load />
  </div>
</section>

<style>
  #portfolio {
    position: relative;
    padding-bottom: 240px;
  }

  /* Placeholder temporaire */
  .portfolio-placeholder {
    background: rgba(96, 165, 250, 0.1);
    border: 2px dashed rgba(96, 165, 250, 0.3);
    border-radius: var(--border-radius-lg);
    padding: var(--spacing-20);
    text-align: center;
    color: var(--color-text-secondary);
    font-style: italic;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>
