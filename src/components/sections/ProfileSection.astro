---
import SocialButtons from '../ui/SocialButtons.vue';
---

<section id="profile" class="section bg-alt">
  <div class="container">
    <div class="section-header">
      <h2>Profil</h2>
      <div class="separator-h separator-h-gradient"></div>
      <p class="section-description">
        Développeur web passionné par la création d'expériences modernes et performantes.
      </p>
    </div>
    <div class="linux-window neon-mask rounded-lg">
      <div class="linux-bar">
        <span class="linux-title">> noctua/profil.dev</span>
      </div>
      <div class="profile-content d-grid ai-center">
        <div class="profile-identity card tt-center pi-center p-relative">
          <div class="profile-video-container octagon d-flex jc-center ai-center">
            <video autoplay muted loop class="octagon p-relative">
              <source src="/meta-noc-cropped.mp4" type="video/mp4" />
            </video>
            <div class="profile-video-overlay p-absolute w-100 h-100"></div>
          </div>
          <p class="name">Geoffrey</p>
          <p class="profile-tagline">Passionné par l'innovation</p>
        </div>

        <div class="profile-status card p-relative d-flex fd-column ai-center jc-center gap-4">
          <p class="profile-role">Développeur d'application</p>
          <div class="status-badge d-flex ai-center p-relative gap-2">
            <span>Disponible en freelance</span>
            <div class="status-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512">
                <!--!Font Awesome Free v7.1.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.-->
                <path
                  d="M434.8 70.1c14.3 10.4 17.5 30.4 7.1 44.7l-256 352c-5.5 7.6-14 12.3-23.4 13.1s-18.5-2.7-25.1-9.3l-128-128c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0l101.5 101.5 234-321.7c10.4-14.3 30.4-17.5 44.7-7.1z"
                >
                </path>
              </svg>
            </div>
          </div>

          <SocialButtons client:load />
        </div>

        <div class="profile-chat card p-relative h-100">
          <div class="profile-icon-message d-flex ai-center jc-center p-absolute">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
              <!-- !Font Awesome Free v7.1.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2025 Fonticons, Inc. -->
              <path
                d="M64 416L64 192C64 139 107 96 160 96L480 96C533 96 576 139 576 192L576 416C576 469 533 512 480 512L360 512C354.8 512 349.8 513.7 345.6 516.8L230.4 603.2C226.2 606.3 221.2 608 216 608C202.7 608 192 597.3 192 584L192 512L160 512C107 512 64 469 64 416z"
              >
              </path>
            </svg>
          </div>
          <div class="chat-bubbles d-flex fd-column jc-center gap-8 h-100">
            <div class="chat-bubble">
              <span class="hello-greeting">Hello ! 👋</span>
            </div>
            <div class="chat-bubble">
              <p>
                Je suis développeur d'application diplômé de l'école Openclassrooms.
                <br />
                Passionné par la création d'interfaces modernes et fluides, j'aime relever de nouveaux défis techniques et
                créatifs.
              </p>
            </div>
            <div class="chat-bubble">
              <p>
                Je vous présente ici mes compétences et mon expérience.
                <br />
                Que ce soit pour un projet, un échange technique ou simplement discuter dev, n'hésitez pas à me contacter
                !
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
