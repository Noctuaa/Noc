---

---

<section id="profile" class="section bg-alt z-1 ow-hidden">
  <div class="container">
    <div class="section-header">
      <h2>À propos</h2>
      <div class="separator-h separator-h-gradient"></div>
      <p class="section-description">Développeur passionné par la création d'expériences modernes et performantes.</p>
    </div>
    <div class="profile-content p-relative d-grid jc-center">
      <!-- Card: header (full width) -->
      <div class="profile-header card d-flex">
        <div class="profile-identity d-flex fd-column jc-center gap-2">
          <p class="profile-role m-0">Développeur d'application</p>
          <p class="profile-tagline m-0">Curieux, rigoureux, attentif aux détails qui font la différence.</p>
        </div>
        <div class="icon-header js-end">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512">
            <!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.-->
            <path
              d="M360.8 1.2c-17-4.9-34.7 5-39.6 22l-128 448c-4.9 17 5 34.7 22 39.6s34.7-5 39.6-22l128-448c4.9-17-5-34.7-22-39.6zm64.6 136.1c-12.5 12.5-12.5 32.8 0 45.3l73.4 73.4-73.4 73.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0l96-96c12.5-12.5 12.5-32.8 0-45.3l-96-96c-12.5-12.5-32.8-12.5-45.3 0zm-274.7 0c-12.5-12.5-32.8-12.5-45.3 0l-96 96c-12.5 12.5-12.5 32.8 0 45.3l96 96c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L77.3 256 150.6 182.6c12.5-12.5 12.5-32.8 0-45.3z"
            >
            </path>
          </svg>
        </div>
      </div>

      <!-- Video circle + binary ring -->
      <div class="profile-avatar p-relative z-2 d-flex js-center">
        <!-- Binary ring -->
        <svg class="profile-ring p-absolute" viewBox="0 0 266 266" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <path id="ring-path" d="M 133,133 m -119,0 a 119,119 0 1,1 238,0 a 119,119 0 1,1 -238,0"></path>
          </defs>
          <text class="ring-text">
            <textPath href="#ring-path">
              1001010110 010 001 10010 1100101 01001 10110 0010 · 1001 010110 010 001 10010 1100101 01001 10110 0010 ·
            </textPath>
          </text>
        </svg>

        <!-- Video -->
        <div class="profile-video-container ow-hidden">
          <video autoplay muted loop>
            <source src="/meta-noc-cropped.mp4" type="video/mp4" />
          </video>
        </div>
      </div>

      <!-- Card: chat (bottom left) -->
      <div class="profile-chat card d-grid gap-6 h-100">
        <div class="icon-header">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
            <path
              d="M64 416L64 192C64 139 107 96 160 96L480 96C533 96 576 139 576 192L576 416C576 469 533 512 480 512L360 512C354.8 512 349.8 513.7 345.6 516.8L230.4 603.2C226.2 606.3 221.2 608 216 608C202.7 608 192 597.3 192 584L192 512L160 512C107 512 64 469 64 416z"
            >
            </path>
          </svg>
        </div>

        <div class="chat-bubbles d-flex fd-column gap-5 h-100">
          <div class="chat-bubble">
            <span class="hello-greeting">Hello ! 👋</span>
          </div>
          <div class="chat-bubble">
            <p>
              Je m'appelle Geoffrey et je suis développeur d'application. Je conçois des interfaces modernes et
              performantes.
            </p>
          </div>
          <div class="chat-bubble">
            <p>
              J'aime relever de nouveaux défis techniques et créatifs. Je vous présente mes compétences — parlons de
              votre projet !
            </p>
          </div>
        </div>
      </div>

      <!-- Card: info (bottom right) -->
      <div class="profile-info card d-grid gap-6 h-100">
        <div class="icon-header">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
            <!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.-->
            <path
              d="M256 512a256 256 0 1 0 0-512 256 256 0 1 0 0 512zM224 160a32 32 0 1 1 64 0 32 32 0 1 1 -64 0zm-8 64l48 0c13.3 0 24 10.7 24 24l0 88 8 0c13.3 0 24 10.7 24 24s-10.7 24-24 24l-80 0c-13.3 0-24-10.7-24-24s10.7-24 24-24l24 0 0-64-24 0c-13.3 0-24-10.7-24-24s10.7-24 24-24z"
            >
            </path>
          </svg>
        </div>
        <div class="d-grid as-start gap-6">
          <div class="d-flex ai-start gap-4">
            <div class="info-icon-wrapper d-grid pi-center">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512">
                <path
                  d="M215.7 499.2C267 435 384 279.4 384 192C384 86 298 0 192 0S0 86 0 192c0 87.4 117 243 168.3 307.2c12.3 15.3 35.1 15.3 47.4 0zM192 128a64 64 0 1 1 0 128 64 64 0 1 1 0-128z"
                >
                </path>
              </svg>
            </div>
            <div>
              <p class="info-label">Localisation</p>
              <p class="info-value">France · Remote</p>
            </div>
          </div>
          <div class="separator-h"></div>
          <div class="info-item d-flex ai-center gap-4">
            <div class="info-icon-wrapper d-flex ai-center jc-center">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 512">
                <path
                  d="M320 32c-8.1 0-16.1 1.4-23.7 4.1L15.8 137.4C6.3 140.9 0 149.9 0 160s6.3 19.1 15.8 22.6l57.9 20.9C57.3 229.3 48 259.8 48 291.9l0 28.1c0 28.4-10.8 57.7-22.3 80.8c-6.5 13-0.6 28.9 12.3 34.6c8.5 3.7 18.3 3.1 26.5-1.8c2.3-1.3 4.5-2.8 6.7-4.3c14.2-9.8 30.6-18.3 47.6-23.7c22.8-7.3 46.6-5.1 67.4 8l1.5 0.9c4.5 2.7 9.2 5.2 14 7.4C192.3 441.7 256.3 480 320 480s127.7-38.3 118.3-87.1c4.8-2.2 9.5-4.7 14-7.4l1.5-.9c20.8-13.1 44.6-15.3 67.4-8c17 5.4 33.4 13.9 47.6 23.7c2.2 1.5 4.4 3 6.7 4.3c8.2 4.9 18 5.5 26.5 1.8c12.9-5.7 18.8-21.6 12.3-34.6C602.8 349.7 592 320.4 592 292l0-28.1c0-32.1-9.3-62.6-25.7-88.3l57.9-20.9C633.7 179.1 640 170.1 640 160s-6.3-19.1-15.8-22.6L343.7 36.1C336.1 33.4 328.1 32 320 32zM128 408c0 35.3 85.96 64 192 64s192-28.7 192-64L512 288.8 354.9 346c-11.1 3.9-22.9 5.9-34.9 5.9s-23.8-2-34.9-5.9L128 288.8 128 408z"
                >
                </path>
              </svg>
            </div>
            <div>
              <p class="info-label">Formation</p>
              <p class="info-value">Développeur d'application</p>
              <p class="info-sub">Openclassrooms · RNCP Niv. 6</p>
            </div>
          </div>
          <div class="separator-h"></div>
          <!-- Availability -->
          <div class="info-item d-flex ai-center gap-4">
            <div class="info-icon-wrapper d-flex ai-center jc-center">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512">
                <path
                  d="M438.6 105.4c12.5 12.5 12.5 32.8 0 45.3l-256 256c-12.5 12.5-32.8 12.5-45.3 0l-128-128c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0L160 338.7 393.4 105.4c12.5-12.5 32.8-12.5 45.3 0z"
                >
                </path>
              </svg>
            </div>
            <div>
              <p class="info-label">Disponibilité</p>
              <div class="d-flex ai-center gap-2">
                <p class="info-value">Disponible en freelance</p>
                <div class="status-icon"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
