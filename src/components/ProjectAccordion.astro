---
import { Image } from 'astro:assets';
import weatherImg from '../images/weather.webp';
import chaletsImg from '../images/chalets.webp';
import type { ImageMetadata } from 'astro';

type Project = {
  id: number;
  title: string;
  link: string;
  tags: string[];
  description: string;
  image: ImageMetadata;
};

// Portfolio projects list
const projects: Project[] = [
  {
    id: 1,
    title: 'SkyCast',
    link: 'https://weather.nocdev.fr/',
    tags: ['Vue.js', 'API Weather', 'Responsive'],
    description: 'Application météo temps réel avec API de géolocalisation et design responsive.',
    image: weatherImg,
  },
  {
    id: 3,
    title: 'EstateHub',
    link: 'https://nocimmo.nocdev.fr/',
    tags: ['Vue.js', 'Laravel', 'MySQL'],
    description: 'Plateforme immobilière full-stack avec système de recherche avancée et gestion des annonces.',
    image: chaletsImg,
  },
];
---

<ul class="accordion">
  {
    projects.map((project) => (
      <li class="project-item neon-mask">
        <Image src={project.image} alt={project.title} class="project-img" />
        <span class="title-vertical">{project.title}</span>
        <div class="project-content">
          <p class="project-title">{project.title}</p>
          <p class="project-description">{project.description}</p>
          <ul class="project-tags">
            {project.tags.map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>
          <a href={project.link} class="btn btn-outline" target="_blank" aria-label={`Voir le projet ${project.title}`}>
            Voir le projet
          </a>
        </div>
      </li>
    ))
  }
</ul>

<script>
  const accordion = document.querySelector<HTMLElement>('.accordion');

  // Init first item as active
  accordion?.querySelector<HTMLElement>('.project-item')?.classList.add('active');

  accordion?.addEventListener('click', (e) => {
    const item = (e.target as Element).closest('.project-item');
    if (!item) return;
    document.querySelector<HTMLElement>('.project-item.active')?.classList.remove('active');
    item.classList.add('active');
  });

  // Mobile carousel: update active item based on visibility
  if (window.matchMedia('(max-width: 992px)').matches) {
    const carouselObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            accordion?.querySelector<HTMLElement>('.project-item.active')?.classList.remove('active');
            entry.target.classList.add('active');
          }
        });
      },
      { root: accordion, threshold: 0.5 },
    );
    accordion?.querySelectorAll<HTMLElement>('.project-item').forEach((item) => {
      carouselObserver.observe(item);
    });
  }
</script>
