---
import Layout from '../layouts/Layout.astro';
import TechCarousel from '../components/TechCarousel.astro';
import ProjectAccordion from '../components/ProjectAccordion.vue';
import ContactForm from '../components/ContactForm.vue';

const email = import.meta.env.PUBLIC_EMAIL_TO;

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
  <!-- ============ CURTAIN EFFECT ============ -->
  <div class="curtain-container">
    <!-- ============ HERO ============ -->
    <section id="hero" class="section p-relative z-10 d-grid pi-center h-100 ow-hidden">
      <div class="hero-header p-absolute z-50 d-grid w-100 pe-none" aria-hidden="true">
        <div class="hero-deco-left">
          <span class="deco-line-top"></span>
          <span class="deco-line-bottom">
            <span class="square"></span>
          </span>
        </div>
        <div class="hero-deco-right">
          <span class="deco-line-bottom">
            <span class="square"></span>
          </span>
          <span class="deco-line-top"></span>
        </div>
      </div>
      <div class="stars p-absolute z-1 w-100 pe-none"></div>
      <div class="hero-vline vline-l" aria-hidden="true"></div>
      <div class="hero-vline vline-r" aria-hidden="true"></div>
      <div class="hero-aurora" aria-hidden="true"></div>
      <div class="hero-forest" aria-hidden="true"></div>
      <div class="container p-relative z-10">
        <div class="hero-content tt-center d-grid gap-1">
          <h1 data-animate>Nocdev</h1>
          <p data-animate>Developpeur d'application</p>
          <div class="d-flex jc-center">
            <ul class="gap-3 d-flex" data-animate>
              <li>
                <!-- prettier-ignore -->
                <a href="https://github.com/Noctuaa" class="btn-mini btn-gradient-1" target="_blank" rel="noopener">
                       <svg xmlns="http://www.w3.org/2000/svg" width="28" viewBox="0 0 640 640"> <!-- !Font Awesome Free v7.0.1 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2025 Fonticons, Inc. -->
                          <path d="M237.9 461.4C237.9 463.4 235.6 465 232.7 465C229.4 465.3 227.1 463.7 227.1 461.4C227.1 459.4 229.4 457.8 232.3 457.8C235.3 457.5 237.9 459.1 237.9 461.4zM206.8 456.9C206.1 458.9 208.1 461.2 211.1 461.8C213.7 462.8 216.7 461.8 217.3 459.8C217.9 457.8 216 455.5 213 454.6C210.4 453.9 207.5 454.9 206.8 456.9zM251 455.2C248.1 455.9 246.1 457.8 246.4 460.1C246.7 462.1 249.3 463.4 252.3 462.7C255.2 462 257.2 460.1 256.9 458.1C256.6 456.2 253.9 454.9 251 455.2zM316.8 72C178.1 72 72 177.3 72 316C72 426.9 141.8 521.8 241.5 555.2C254.3 557.5 258.8 549.6 258.8 543.1C258.8 536.9 258.5 502.7 258.5 481.7C258.5 481.7 188.5 496.7 173.8 451.9C173.8 451.9 162.4 422.8 146 415.3C146 415.3 123.1 399.6 147.6 399.9C147.6 399.9 172.5 401.9 186.2 425.7C208.1 464.3 244.8 453.2 259.1 446.6C261.4 430.6 267.9 419.5 275.1 412.9C219.2 406.7 162.8 398.6 162.8 302.4C162.8 274.9 170.4 261.1 186.4 243.5C183.8 237 175.3 210.2 189 175.6C209.9 169.1 258 202.6 258 202.6C278 197 299.5 194.1 320.8 194.1C342.1 194.1 363.6 197 383.6 202.6C383.6 202.6 431.7 169 452.6 175.6C466.3 210.3 457.8 237 455.2 243.5C471.2 261.2 481 275 481 302.4C481 398.9 422.1 406.6 366.2 412.9C375.4 420.8 383.2 435.8 383.2 459.3C383.2 493 382.9 534.7 382.9 542.9C382.9 549.4 387.5 557.3 400.2 555C500.2 521.8 568 426.9 568 316C568 177.3 455.5 72 316.8 72zM169.2 416.9C167.9 417.9 168.2 420.2 169.9 422.1C171.5 423.7 173.8 424.4 175.1 423.1C176.4 422.1 176.1 419.8 174.4 417.9C172.8 416.3 170.5 415.6 169.2 416.9zM158.4 408.8C157.7 410.1 158.7 411.7 160.7 412.7C162.3 413.7 164.3 413.4 165 412C165.7 410.7 164.7 409.1 162.7 408.1C160.7 407.5 159.1 407.8 158.4 408.8zM190.8 444.4C189.2 445.7 189.8 448.7 192.1 450.6C194.4 452.9 197.3 453.2 198.6 451.6C199.9 450.3 199.3 447.3 197.3 445.4C195.1 443.1 192.1 442.8 190.8 444.4zM179.4 429.7C177.8 430.7 177.8 433.3 179.4 435.6C181 437.9 183.7 438.9 185 437.9C186.6 436.6 186.6 434 185 431.7C183.6 429.4 181 428.4 179.4 429.7z"/>
                       </svg>
                    </a>
              </li>
              <li>
                <!-- prettier-ignore -->
                <a href={`mailto:${email}`} class="btn-mini btn-gradient-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" viewBox="0 0 512 512"><!-- !Font Awesome Free v7.0.1 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2025 Fonticons, Inc. -->
                    <path
                      d="M48 64c-26.5 0-48 21.5-48 48 0 15.1 7.1 29.3 19.2 38.4l208 156c17.1 12.8 40.5 12.8 57.6 0l208-156c12.1-9.1 19.2-23.3 19.2-38.4 0-26.5-21.5-48-48-48L48 64zM0 196L0 384c0 35.3 28.7 64 64 64l384 0c35.3 0 64-28.7 64-64l0-188-198.4 148.8c-34.1 25.6-81.1 25.6-115.2 0L0 196z"
                    />
                  </svg>
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>
      <div class="hero-footer p-absolute z-3 d-flex jc-center w-100">
        <a href="#profile" class="hero-scroll" aria-label="Défiler vers le bas" data-animate>
          <span class="hero-scroll-wheel"></span>
        </a>
      </div>
    </section>

    <!-- ============ PROFILE ============ -->
    <section id="profile" class="section bg-alt z-1 ow-hidden">
      <div class="container">
        <div class="section-header">
          <h2 data-animate>À propos</h2>
          <div class="separator-h separator-h-gradient" data-animate></div>
          <p class="section-description" data-animate>
            Développeur passionné par la création d'expériences modernes et performantes.
          </p>
        </div>
        <div class="profile-content p-relative d-grid jc-center">
          <!-- Card: header (full width) -->
          <div class="profile-header card d-flex" data-animate>
            <div class="profile-identity d-flex fd-column jc-center gap-2">
              <p class="profile-role m-0">Développeur d'application</p>
              <p class="profile-tagline m-0">Curieux, rigoureux, attentif aux détails qui font la différence.</p>
            </div>
            <div class="icon-header js-end">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512">
                <!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.-->
                <path
                  d="M360.8 1.2c-17-4.9-34.7 5-39.6 22l-128 448c-4.9 17 5 34.7 22 39.6s34.7-5 39.6-22l128-448c4.9-17-5-34.7-22-39.6zm64.6 136.1c-12.5 12.5-12.5 32.8 0 45.3l73.4 73.4-73.4 73.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0l96-96c12.5-12.5 12.5-32.8 0-45.3l-96-96c-12.5-12.5-32.8-12.5-45.3 0zm-274.7 0c-12.5-12.5-32.8-12.5-45.3 0l-96 96c-12.5 12.5-12.5 32.8 0 45.3l96 96c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L77.3 256 150.6 182.6c12.5-12.5 12.5-32.8 0-45.3z"
                >
                </path>
              </svg>
            </div>
          </div>

          <!-- Video circle + binary ring -->
          <div class="profile-avatar p-relative z-2 d-flex js-center" data-animate>
            <!-- Binary ring -->
            <svg class="profile-ring p-absolute" viewBox="0 0 266 266" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <path id="ring-path" d="M 133,133 m -119,0 a 119,119 0 1,1 238,0 a 119,119 0 1,1 -238,0"></path>
              </defs>
              <text class="ring-text">
                <textPath href="#ring-path">
                  1001010110 010 001 10010 1100101 01001 10110 0010 · 1001 010110 010 001 10010 1100101 01001 10110 0010
                  ·
                </textPath>
              </text>
            </svg>

            <!-- Video -->
            <div class="profile-video-container ow-hidden">
              <video autoplay muted loop>
                <source src="/profile-video.mp4" type="video/mp4" />
              </video>
            </div>
          </div>

          <!-- Card: chat (bottom left) -->
          <div class="profile-chat card d-grid gap-6 h-100" data-animate>
            <div class="icon-header">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
                <path
                  d="M64 416L64 192C64 139 107 96 160 96L480 96C533 96 576 139 576 192L576 416C576 469 533 512 480 512L360 512C354.8 512 349.8 513.7 345.6 516.8L230.4 603.2C226.2 606.3 221.2 608 216 608C202.7 608 192 597.3 192 584L192 512L160 512C107 512 64 469 64 416z"
                >
                </path>
              </svg>
            </div>

            <div class="chat-bubbles d-flex fd-column gap-5 h-100">
              <div class="chat-bubble" data-animate>
                <span class="hello-greeting">Hello ! 👋</span>
              </div>
              <div class="chat-bubble" data-animate>
                <p>
                  Je m'appelle Geoffrey et je suis développeur d'application. Je conçois des interfaces modernes et
                  performantes.
                </p>
              </div>
              <div class="chat-bubble" data-animate>
                <p>
                  J'aime relever de nouveaux défis techniques et créatifs. Je vous présente mes compétences — parlons de
                  votre projet !
                </p>
              </div>
            </div>
          </div>

          <!-- Card: info (bottom right) -->
          <div class="profile-info card d-grid gap-6 h-100" data-animate>
            <div class="icon-header">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
                <!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.-->
                <path
                  d="M256 512a256 256 0 1 0 0-512 256 256 0 1 0 0 512zM224 160a32 32 0 1 1 64 0 32 32 0 1 1 -64 0zm-8 64l48 0c13.3 0 24 10.7 24 24l0 88 8 0c13.3 0 24 10.7 24 24s-10.7 24-24 24l-80 0c-13.3 0-24-10.7-24-24s10.7-24 24-24l24 0 0-64-24 0c-13.3 0-24-10.7-24-24s10.7-24 24-24z"
                >
                </path>
              </svg>
            </div>
            <div class="d-grid as-start gap-6">
              <!-- Location -->
              <div class="info-item d-flex ai-start gap-4" data-animate>
                <div class="info-icon-wrapper d-grid pi-center">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512">
                    <path
                      d="M215.7 499.2C267 435 384 279.4 384 192C384 86 298 0 192 0S0 86 0 192c0 87.4 117 243 168.3 307.2c12.3 15.3 35.1 15.3 47.4 0zM192 128a64 64 0 1 1 0 128 64 64 0 1 1 0-128z"
                    >
                    </path>
                  </svg>
                </div>
                <div>
                  <p class="info-label">Localisation</p>
                  <p class="info-value">France · Remote</p>
                </div>
              </div>
              <!-- Education -->
              <div class="info-item d-flex ai-center gap-4" data-animate>
                <div class="info-icon-wrapper d-flex ai-center jc-center">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 512">
                    <path
                      d="M320 32c-8.1 0-16.1 1.4-23.7 4.1L15.8 137.4C6.3 140.9 0 149.9 0 160s6.3 19.1 15.8 22.6l57.9 20.9C57.3 229.3 48 259.8 48 291.9l0 28.1c0 28.4-10.8 57.7-22.3 80.8c-6.5 13-0.6 28.9 12.3 34.6c8.5 3.7 18.3 3.1 26.5-1.8c2.3-1.3 4.5-2.8 6.7-4.3c14.2-9.8 30.6-18.3 47.6-23.7c22.8-7.3 46.6-5.1 67.4 8l1.5 0.9c4.5 2.7 9.2 5.2 14 7.4C192.3 441.7 256.3 480 320 480s127.7-38.3 118.3-87.1c4.8-2.2 9.5-4.7 14-7.4l1.5-.9c20.8-13.1 44.6-15.3 67.4-8c17 5.4 33.4 13.9 47.6 23.7c2.2 1.5 4.4 3 6.7 4.3c8.2 4.9 18 5.5 26.5 1.8c12.9-5.7 18.8-21.6 12.3-34.6C602.8 349.7 592 320.4 592 292l0-28.1c0-32.1-9.3-62.6-25.7-88.3l57.9-20.9C633.7 179.1 640 170.1 640 160s-6.3-19.1-15.8-22.6L343.7 36.1C336.1 33.4 328.1 32 320 32zM128 408c0 35.3 85.96 64 192 64s192-28.7 192-64L512 288.8 354.9 346c-11.1 3.9-22.9 5.9-34.9 5.9s-23.8-2-34.9-5.9L128 288.8 128 408z"
                    >
                    </path>
                  </svg>
                </div>
                <div>
                  <p class="info-label">Formation</p>
                  <p class="info-value">Développeur d'application</p>
                  <p class="info-sub">Openclassrooms · RNCP Niv. 6</p>
                </div>
              </div>
              <!-- Availability -->
              <div class="info-item d-flex ai-center gap-4" data-animate>
                <div class="info-icon-wrapper d-flex ai-center jc-center">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512">
                    <path
                      d="M438.6 105.4c12.5 12.5 12.5 32.8 0 45.3l-256 256c-12.5 12.5-32.8 12.5-45.3 0l-128-128c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0L160 338.7 393.4 105.4c12.5-12.5 32.8-12.5 45.3 0z"
                    >
                    </path>
                  </svg>
                </div>
                <div>
                  <p class="info-label">Disponibilité</p>
                  <div class="d-flex ai-center gap-2">
                    <p class="info-value">Disponible en freelance</p>
                    <div class="status-icon"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- ============ COMPETENCES ============ -->
  <section id="competences" class="section bg-surface p-relative">
    <div class="container">
      <div class="section-header">
        <h2 data-animate>Compétences</h2>
        <div class="separator-h separator-h-gradient" data-animate></div>
        <p class="section-description" data-animate>
          Technologies, outils et environnement pour créer des projets performants.
        </p>
      </div>
    </div>
    <TechCarousel />
  </section>

  <!-- ============ PORTFOLIO ============ -->
  <section id="portfolio" class="section bg-alt">
    <div class="container">
      <div class="section-header">
        <h2>Portfolio</h2>
        <div class="separator-h separator-h-gradient"></div>
        <p class="section-description">Découvrez mes projets et réalisations techniques.</p>
      </div>
      <ProjectAccordion client:load />
    </div>
  </section>

  <!-- ============ CONTACT ============ -->
  <section id="contact" class="section bg-surface">
    <div class="container">
      <div class="section-header">
        <h2>Contact</h2>
        <div class="separator-h separator-h-gradient"></div>
        <p class="section-description">Disponible pour vos projets web et applications.</p>
      </div>
      <div class="contact-form">
        <ContactForm client:load />
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    // Génération des étoiles
    const starsContainer = document.querySelector('.stars');

    // Grille 6 colonnes x 5 lignes = 30 étoiles réparties uniformément
    const cols = 5,
      rows = 5;

    for (let row = 0; row < rows; row++) {
      for (let col = 0; col < cols; col++) {
        const star = document.createElement('span');
        star.className = 'star';
        star.textContent = '+';

        // Position dans la cellule + décalage aléatoire (jitter)
        // → distribution uniforme mais aspect naturel
        star.style.left = `${(col / cols) * 100 + Math.random() * (100 / cols)}%`;
        star.style.top = `${(row / rows) * 100 + Math.random() * (100 / rows)}%`;

        // Délai aléatoire pour que les étoiles ne clignotent pas toutes en même temps
        star.style.animationDelay = `${Math.random() * 3}s`;

        starsContainer.appendChild(star);
      }
    }
  });
</script>
